# ============================================================
# Runtime
# ============================================================
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
BODY_LIMIT=1mb
CORS_ORIGIN=*

# ============================================================
# Database
# ============================================================
MONGO_URI=mongodb://127.0.0.1:27017/cems_dev

# ============================================================
# Security / Auth
# ============================================================
BCRYPT_COST=12
JWT_ACCESS_SECRET=replace-with-32+-char-random-string
JWT_REFRESH_SECRET=replace-with-another-32+-char-random-string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
JWT_ISSUER=cems-backend
JWT_AUDIENCE=cems-clients

# ============================================================
# Logistics
# ============================================================
GATE_PASS_HMAC_SECRET=replace-with-32+-char-random-string
GATE_PASS_TTL_HOURS=12
