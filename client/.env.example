# -----------------------------------------------------------------------------
# CEMS Frontend — environment variables
# Copy to .env and edit values for your environment. NEVER commit real secrets.
# -----------------------------------------------------------------------------

# Backend base URL — must include the API version prefix
VITE_API_BASE_URL=http://localhost:4000/api/v1

# Branding
VITE_APP_NAME=CEMS
VITE_APP_TAGLINE=College Event Management System
VITE_COLLEGE_NAME=GLA University
VITE_BRAND_INITIAL=C

# Auth — localStorage keys (change if you run multiple apps on the same origin)
VITE_ACCESS_TOKEN_KEY=cems.access_token
VITE_REFRESH_TOKEN_KEY=cems.refresh_token
VITE_USER_KEY=cems.user
VITE_RSVPS_KEY=cems.rsvps
VITE_PASSES_KEY=cems.passes

# Network behaviour
VITE_REQUEST_TIMEOUT_MS=15000
VITE_PAGE_SIZE=20

# Form vocab — comma-separated. Server is the source of truth, these are UI hints.
VITE_DEPARTMENTS=CSE,ECE,ME,CE,EEE,IT,AIML,MBA
VITE_YEARS=1,2,3,4,5
VITE_ASSET_CATEGORIES=PROJECTOR,MICROPHONE,SPEAKER,CHAIR,TABLE,OTHER

# Venues — pipe-separated id|name pairs. Paste the ObjectIds your backend uses.
# Leave empty to fall back to a free-form venueId text input.
# Example: VITE_VENUES=64a1...|Main Auditorium,64a2...|Seminar Hall A
VITE_VENUES=

# Dev server port (optional)
VITE_DEV_PORT=5173
