# Belt-and-braces root .gitignore. Each subdir has its own — this catches
# anything that might land at the repo root.

# Dependencies
node_modules/
**/node_modules/

# Environment (NEVER commit real secrets)
.env
.env.local
.env.*.local
**/.env
**/.env.local
**/.env.*.local
!.env.example
!**/.env.example

# Build artifacts
dist/
build/
**/dist/
**/build/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Editor / OS
.vscode/
.idea/
.DS_Store
*.swp
